# Copy to .env and fill in. The schema lives in /src/env.js.
# This file is committed — keep secrets out of it.

# Postgres (local Docker — see docker-compose.yml)
DATABASE_URL="postgresql://postgres:password@localhost:5434/porthub"

# Server-side GitHub PAT (public-read scope) for scraping users' profiles.
# This is DIFFERENT from the GitHub OAuth client below — that one is for sign-in.
GITHUB_TOKEN=""

# Anthropic API key — required once MOCK_LLM="false".
ANTHROPIC_API_KEY=""
MOCK_LLM="true"

# Anthropic model IDs (override per-env). Pricing for any model you set here
# must be present in src/server/llm/cost.ts → PRICING.
ANTHROPIC_MODEL_FACTS="claude-haiku-4-5"
ANTHROPIC_MODEL_DESIGN="claude-opus-4-8"

# Hard daily LLM spend ceiling (USD). When the day's spend reaches this,
# /api/generate returns 503 until UTC midnight. Leave blank to disable.
DAILY_LLM_BUDGET_USD=""

# Root domain for subdomain routing. "localhost:3000" in dev, "porthub.dev" in prod.
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"

# ─── BetterAuth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Public base URL of the app. Match this to where the app actually serves.
BETTER_AUTH_URL="http://localhost:3000"

# ─── OAuth: Google ───────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── OAuth: GitHub ───────────────────────────────────────────────────────────
# Create at https://github.com/settings/developers (New OAuth App)
# Authorization callback URL: ${BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── Email: Resend (magic links) ─────────────────────────────────────────────
# Get a key at https://resend.com/api-keys
# In prod use a verified domain; in dev you can use "onboarding@resend.dev".
RESEND_API_KEY=""
EMAIL_FROM="PortHub <onboarding@resend.dev>"
