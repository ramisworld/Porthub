# Copy to .env and fill in. The schema lives in /src/env.js.
# This file is committed — keep secrets out of it.

# Postgres (local Docker — see docker-compose.yml)
DATABASE_URL="postgresql://postgres:password@localhost:5434/porthub"

# GitHub PAT with public read — required for the live GitHub fetch.
GITHUB_TOKEN=""

# Anthropic API key — required once MOCK_LLM="false".
ANTHROPIC_API_KEY=""

# "true" stubs all model calls (zero spend); "false" runs Haiku (facts) + Opus (design).
MOCK_LLM="true"

# Root domain for subdomain routing. "localhost:3000" in dev, "porthub.app" in prod.
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"
