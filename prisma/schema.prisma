// PortHub Prisma schema — see docs/ARCHITECTURE.md §6
// learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── BetterAuth (Phase 2) ─────────────────────────────
// Field names match BetterAuth's expected schema; do not rename without also
// adjusting the auth config. Session is server-side (DB row + httpOnly cookie).

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String          @unique
  emailVerified  Boolean         @default(false)
  image          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  sessions       Session[]
  accounts       Account[]
  portfolios     Portfolio[]
  generationLock GenerationLock?
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String    @db.Text
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@index([identifier])
}

// ───────────────────────── PortHub domain models ────────────────────────────

// A generated portfolio. From Phase 2 onward, ownerId is always set on new rows.
// Pre-Phase-2 rows may still be ownerless until they're claimed or pruned.
model Portfolio {
  id             String         @id @default(cuid())
  ownerId        String?        @unique
  owner          User?          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  githubUsername String
  slug           String         @unique
  vibe           String
  profileData    Json
  designSpec     Json?
  engineVersion  String?
  template       String         @default("terminalNexus")
  code           String?        @db.Text
  isPublic       Boolean        @default(true)
  views          Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  customDomain   CustomDomain?

  @@index([githubUsername])
}

// A user-owned hostname (e.g. portfolio.max.com) attached to a Portfolio.
//
// Beta cap: one CustomDomain per Portfolio (and a Portfolio is one-per-user),
// so effectively one custom domain per account. The hostname is verified +
// served by Cloudflare for SaaS — `cfHostnameId` is the id Cloudflare gives
// us when we register the hostname; we use it to poll status + delete later.
model CustomDomain {
  id              String    @id @default(cuid())
  portfolioId     String    @unique
  portfolio       Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  hostname        String    @unique
  // Cloudflare's id for this custom hostname (legacy CF-for-SaaS path).
  // Nullable so we can persist the row even if the call fails mid-creation.
  cfHostnameId    String?   @unique
  // Railway Custom Domains API: the id Railway assigns to this domain, plus
  // the per-domain DNS values Railway returns (CNAME target + verify TXT).
  railwayDomainId   String? @unique
  cnameHost         String? // Railway's CNAME host label ("" = apex/@)
  cnameTarget       String? // e.g. w9kc0szy.up.railway.app
  verificationHost  String? // zone-relative TXT name, e.g. _railway-verify
  verificationToken String? // TXT value to prove ownership
  // Local rollup status: pending | active | action_needed | error.
  status          String    @default("pending")
  // Raw provider sub-statuses cached for the UI.
  ownershipStatus String?
  sslStatus       String?
  errorReason     String?
  lastCheckedAt   DateTime?
  activatedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model GitHubCache {
  username  String   @id
  raw       Json
  fetchedAt DateTime @default(now())
}

// Short-lived lock acquired before expensive GitHub/LLM work starts.
// This prevents multi-tab duplicate generation attempts from burning cost before
// the one-portfolio-per-user database constraint can reject the race loser.
model GenerationLock {
  id             String   @id @default(cuid())
  ownerId        String   @unique
  owner          User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  githubUsername String
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@index([expiresAt])
}
